# ============================================================
# RIVIERA CHERCHELL — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE PAS commiter .env.local dans git
# ============================================================

# --- Supabase ---
# Récupérer depuis : https://app.supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clé service (pour les API routes côté serveur — ne jamais exposer au client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Resend (emails) ---
# Créer un compte sur https://resend.com — gratuit jusqu'à 3 000 emails/mois
# Ajouter et vérifier votre domaine dans Resend > Domains
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
